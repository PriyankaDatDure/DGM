# Copy to .env.local and fill in values.
# For local dev through SSH: run `npm run db:tunnel` first, then point DATABASE_* at localhost.

# --- App database (use 127.0.0.1 when SSH tunnel is running) ---
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5433
DATABASE_NAME=car_climate_conceptual
DATABASE_USER=car_conceptual_user
DATABASE_PASSWORD=

AUTH_SECRET=

# --- Forecast summary enhancement API ---
DGM_BOT_ENHANCE_URL=https://dgmcar.1dataconnect.com/dgm_bot/api/v1/enhance
DGM_BOT_API_KEY=

# --- SSH tunnel (local dev only) ---
SSH_HOST=
SSH_PORT=22
SSH_USER=
# Use password OR key file (prefer key in production)
SSH_PASSWORD=
# SSH_KEY_PATH=C:/Users/you/.ssh/id_rsa
# SSH_KEY_PASSPHRASE=

# Where Postgres listens on the remote server (usually localhost there)
SSH_REMOTE_DB_HOST=127.0.0.1
SSH_REMOTE_DB_PORT=5433
# Local port the tunnel binds to (must match DATABASE_PORT above)
SSH_LOCAL_PORT=5433

# --- i18n (optional) ---
# DEFAULT_LOCALE=fr
